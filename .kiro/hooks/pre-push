#!/usr/bin/env bash
# =============================================================================
# Pre-Push Hook: AI Code Review with Kiro CLI Agents
# Runs two dedicated agents in parallel:
#   1. security-reviewer  — vulnerabilities, secrets, auth issues
#   2. quality-reviewer   — duplicates, structure, logic, missing tests
# =============================================================================

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ── Escape hatch ─────────────────────────────────────────
if [ "${SKIP_AI_REVIEW:-}" = "1" ]; then
  echo -e "${YELLOW}⏭  Skipping AI code review (SKIP_AI_REVIEW=1)${NC}"
  exit 0
fi

# ── Check kiro-cli is available ──────────────────────────
if ! command -v kiro-cli &> /dev/null; then
  echo -e "${YELLOW}⚠  kiro-cli not found — skipping AI review${NC}"
  echo -e "${YELLOW}   Install kiro-cli or set SKIP_AI_REVIEW=1 to suppress${NC}"
  exit 0
fi

# ── Collect the diff being pushed ────────────────────────
REMOTE="$1"
URL="$2"

CHANGES=""
while read -r LOCAL_REF LOCAL_OID REMOTE_REF REMOTE_OID; do
  if [ "$LOCAL_OID" = "0000000000000000000000000000000000000000" ]; then
    continue  # branch deletion
  fi

  if [ "$REMOTE_OID" = "0000000000000000000000000000000000000000" ]; then
    # New branch — diff against main/master
    BASE=$(git merge-base HEAD main 2>/dev/null || git merge-base HEAD master 2>/dev/null || echo "")
    if [ -n "$BASE" ]; then
      CHANGES=$(git diff "$BASE" HEAD -- '*.py' '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' \
        ':!package-lock.json' ':!**/node_modules/**' ':!**/dist/**' \
        ':!**/cdk.out/**' ':!**/.ruff_cache/**' ':!**/coverage_html/**')
    else
      CHANGES=$(git diff HEAD~1 HEAD -- '*.py' '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' \
        ':!package-lock.json' ':!**/node_modules/**' ':!**/dist/**' \
        ':!**/cdk.out/**' ':!**/.ruff_cache/**' ':!**/coverage_html/**')
    fi
  else
    CHANGES=$(git diff "$REMOTE_OID" "$LOCAL_OID" -- '*.py' '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' \
      ':!package-lock.json' ':!**/node_modules/**' ':!**/dist/**' \
      ':!**/cdk.out/**' ':!**/.ruff_cache/**' ':!**/coverage_html/**')
  fi
done

if [ -z "$CHANGES" ]; then
  echo -e "${GREEN}✓ No code changes to review${NC}"
  exit 0
fi

# Truncate large diffs to stay within token limits
MAX_CHARS=80000
if [ ${#CHANGES} -gt $MAX_CHARS ]; then
  CHANGES="${CHANGES:0:$MAX_CHARS}

... [DIFF TRUNCATED — first ~80K chars shown] ..."
  echo -e "${YELLOW}⚠  Large diff — truncated to ${MAX_CHARS} chars${NC}"
fi

FILE_COUNT=$(echo "$CHANGES" | grep -c '^diff --git' || true)

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║          🔍 AI Pre-Push Code Review                     ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
echo -e "${BLUE}  Files changed: ${FILE_COUNT}${NC}"
echo -e "${BLUE}  Remote: ${REMOTE} (${URL})${NC}"
echo ""

# ── Temp files for output ────────────────────────────────
SECURITY_OUTPUT=$(mktemp)
QUALITY_OUTPUT=$(mktemp)
trap 'rm -f "$SECURITY_OUTPUT" "$QUALITY_OUTPUT"' EXIT

# ── Build review prompts ─────────────────────────────────
SECURITY_PROMPT="Review the following git diff for security issues. Follow your system prompt instructions exactly.

GIT DIFF:
$CHANGES"

QUALITY_PROMPT="Review the following git diff for code quality issues. Follow your system prompt instructions exactly.

GIT DIFF:
$CHANGES"

# ── Run both agents in parallel ──────────────────────────
echo -e "${YELLOW}▶ Agent 1: security-reviewer${NC}"
echo -e "${YELLOW}▶ Agent 2: quality-reviewer${NC}"
echo ""

kiro-cli chat --agent security-reviewer --no-interactive --trust-all-tools "$SECURITY_PROMPT" > "$SECURITY_OUTPUT" 2>&1 &
SECURITY_PID=$!

kiro-cli chat --agent quality-reviewer --no-interactive --trust-all-tools "$QUALITY_PROMPT" > "$QUALITY_OUTPUT" 2>&1 &
QUALITY_PID=$!

SECURITY_EXIT=0
QUALITY_EXIT=0
wait $SECURITY_PID || SECURITY_EXIT=$?
wait $QUALITY_PID || QUALITY_EXIT=$?

# ── Display results ──────────────────────────────────────
echo -e "${BOLD}${CYAN}┌──────────────────────────────────────────────────────────┐${NC}"
echo -e "${BOLD}${CYAN}│  🛡️  Security Review                                     │${NC}"
echo -e "${BOLD}${CYAN}└──────────────────────────────────────────────────────────┘${NC}"
if [ $SECURITY_EXIT -ne 0 ]; then
  echo -e "${YELLOW}⚠  Security agent failed (exit $SECURITY_EXIT)${NC}"
fi
cat "$SECURITY_OUTPUT"

echo ""
echo -e "${BOLD}${CYAN}┌──────────────────────────────────────────────────────────┐${NC}"
echo -e "${BOLD}${CYAN}│  🧹 Code Quality Review                                  │${NC}"
echo -e "${BOLD}${CYAN}└──────────────────────────────────────────────────────────┘${NC}"
if [ $QUALITY_EXIT -ne 0 ]; then
  echo -e "${YELLOW}⚠  Quality agent failed (exit $QUALITY_EXIT)${NC}"
fi
cat "$QUALITY_OUTPUT"

echo ""

# ── Gate decision ────────────────────────────────────────
BLOCK_PUSH=0

if [ $SECURITY_EXIT -eq 0 ] && grep -q '🚨 CRITICAL SECURITY ISSUES FOUND' "$SECURITY_OUTPUT"; then
  BLOCK_PUSH=1
  echo -e "${RED}${BOLD}✗ Blocked by security review — fix critical issues above${NC}"
fi

if [ $QUALITY_EXIT -eq 0 ] && grep -q '🚫 CODE QUALITY ISSUES — BLOCKING' "$QUALITY_OUTPUT"; then
  BLOCK_PUSH=1
  echo -e "${RED}${BOLD}✗ Blocked by quality review — fix blocking issues above${NC}"
fi

if [ $BLOCK_PUSH -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}To bypass (use sparingly):  SKIP_AI_REVIEW=1 git push${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}${BOLD}✓ AI code review passed — push proceeding${NC}"
echo ""
exit 0
