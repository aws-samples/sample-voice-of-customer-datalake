        "required": false,
        "placeholder": "us, gb, de, fr",
        "secret": false
      }
    ],
    "setup": {
      "title": "Apple App Store Setup",
      "color": "gray",
      "steps": [
        "Find your app on the App Store",
        "Copy the App ID from the URL (e.g., id123456789)",
