{
  "id": "facebook",
  "name": "Facebook",
  "icon": "👍",
  "description": "Page reviews and comments via Meta Graph API",
  "category": "social",
  "version": "1.0.0",

  "infrastructure": {
    "ingestor": {
      "enabled": true,
      "schedule": "rate(5 minutes)",
      "timeout": 120,
      "memory": 256
    }
  },

  "config": [
    {
      "key": "access_token",
      "label": "Access Token",
      "type": "password",
      "required": true,
      "secret": true
    },
    {
      "key": "page_id",
      "label": "Page ID",
      "type": "text",
      "placeholder": "123456789012345",
      "required": true,
      "secret": false
    }
  ],

  "setup": {
    "title": "Facebook Setup",
    "color": "blue",
    "steps": [
      "Go to Meta for Developers (developers.facebook.com)",
      "Create or select an app with Pages API access",
      "Add your Facebook Page to the app",
      "Generate a Page Access Token with pages_read_engagement permission",
      "Get your Page ID from the Page settings"
    ]
  },

  "secrets": {
    "access_token": "",
    "page_id": ""
  }
}
