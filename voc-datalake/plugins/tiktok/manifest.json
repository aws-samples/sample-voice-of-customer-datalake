{
  "id": "tiktok",
  "name": "TikTok",
  "icon": "🎵",
  "description": "Comments and mentions via TikTok API for Business",
  "category": "social",
  "version": "1.0.0",

  "infrastructure": {
    "ingestor": {
      "enabled": true,
      "schedule": "rate(10 minutes)",
      "timeout": 120,
      "memory": 256
    }
  },

  "config": [
    {
      "key": "access_token",
      "label": "Access Token",
      "type": "password",
      "required": true,
      "secret": true
    },
    {
      "key": "refresh_token",
      "label": "Refresh Token",
      "type": "password",
      "required": false,
      "secret": true
    },
    {
      "key": "client_key",
      "label": "Client Key",
      "type": "text",
      "required": false,
      "secret": false
    },
    {
      "key": "client_secret",
      "label": "Client Secret",
      "type": "password",
      "required": false,
      "secret": true
    },
    {
      "key": "business_id",
      "label": "Business ID",
      "type": "text",
      "placeholder": "7000000000000000000",
      "required": false,
      "secret": false
    },
    {
      "key": "video_ids",
      "label": "Video IDs",
      "type": "textarea",
      "placeholder": "7000000000000000001, 7000000000000000002",
      "required": false,
      "secret": false
    }
  ],

  "setup": {
    "title": "TikTok Setup",
    "color": "gray",
    "steps": [
      "Apply for TikTok for Business API access",
      "Create an app in TikTok Developer Portal",
      "Complete OAuth flow to get access token",
      "Optionally add refresh token for auto-renewal",
      "Enter your Business ID or specific Video IDs to monitor"
    ]
  },

  "secrets": {
    "access_token": "",
    "refresh_token": "",
    "client_key": "",
    "client_secret": "",
    "business_id": "",
    "video_ids": "",
    "research_enabled": "false"
  }
}
