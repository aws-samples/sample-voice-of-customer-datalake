{
  "id": "tavily",
  "name": "Tavily Web Search",
  "icon": "🔍",
  "description": "Brand mentions from web search using Tavily API",
  "category": "search",
  "version": "1.0.0",

  "infrastructure": {
    "ingestor": {
      "enabled": true,
      "schedule": "rate(30 minutes)",
      "timeout": 180,
      "memory": 256
    }
  },

  "config": [
    {
      "key": "api_key",
      "label": "API Key",
      "type": "password",
      "required": true,
      "secret": true
    }
  ],

  "setup": {
    "title": "Tavily Setup",
    "color": "blue",
    "steps": [
      "Go to tavily.com and create an account",
      "Navigate to API Keys in your dashboard",
      "Create a new API key",
      "Copy and paste the API key above"
    ]
  },

  "secrets": {
    "api_key": ""
  }
}
