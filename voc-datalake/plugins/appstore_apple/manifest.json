{
  "id": "appstore_apple",
  "name": "Apple App Store",
  "icon": "🍎",
  "description": "App reviews via Apple App Store RSS feed",
  "category": "appstore",
  "version": "1.0.0",

  "infrastructure": {
    "ingestor": {
      "enabled": true,
      "schedule": "rate(15 minutes)",
      "timeout": 120,
      "memory": 256
    }
  },

  "config": [
    {
      "key": "app_id",
      "label": "App ID",
      "type": "text",
      "placeholder": "123456789",
      "required": true,
      "secret": false
    },
    {
      "key": "country_codes",
      "label": "Country Codes",
      "type": "text",
      "placeholder": "us, gb, de, fr",
      "required": false,
      "secret": false
    }
  ],

  "setup": {
    "title": "Apple App Store Setup",
    "color": "gray",
    "steps": [
      "Find your app on the App Store",
      "Copy the App ID from the URL (e.g., id123456789)",
      "Enter just the numeric ID above",
      "Optionally specify country codes (default: us, gb, de, fr)"
    ]
  },

  "secrets": {
    "app_id": "",
    "country_codes": "us,gb,de,fr"
  }
}
