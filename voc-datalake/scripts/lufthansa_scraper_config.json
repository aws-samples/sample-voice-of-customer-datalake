{
  "scrapers": [
    {
      "id": "lufthansa_trustpilot",
      "name": "Lufthansa Trustpilot",
      "enabled": true,
      "base_url": "https://www.trustpilot.com/review/lufthansa.com",
      "urls": [],
      "frequency_minutes": 60,
      "extraction_method": "jsonld",
      "template": "trustpilot",
      "pagination": {
        "enabled": true,
        "param": "page",
        "start": 1,
        "max_pages": 5
      }
    },
    {
      "id": "lufthansa_yelp_frankfurt",
      "name": "Lufthansa Yelp Frankfurt",
      "enabled": false,
      "base_url": "https://www.yelp.com/biz/lufthansa-frankfurt-am-main-3",
      "urls": [
        "https://www.yelp.com/biz/lufthansa-los-angeles-2",
        "https://www.yelp.com/biz/lufthansa-boston",
        "https://www.yelp.com/biz/lufthansa-schiphol"
      ],
      "frequency_minutes": 0,
      "extraction_method": "css",
      "template": "yelp",
      "container_selector": "li[class*=\"margin-b5__\"], [data-review-id], section[aria-label*=\"review\"]",
      "text_selector": "p[class*=\"comment__\"], span[class*=\"raw__\"], p[lang]",
      "rating_selector": "[aria-label*=\"star rating\"], div[class*=\"i-stars\"]",
      "author_selector": "a[href*=\"/user_details\"], [class*=\"user-passport\"] a",
      "date_selector": "span[class*=\"css-\"], time",
      "pagination": {
        "enabled": true,
        "param": "start",
        "start": 0,
        "max_pages": 3
      },
      "_note": "DISABLED: Yelp blocks web scraping. Consider using Yelp Fusion API instead."
    }
  ],
  "notes": {
    "yelp_alternatives": [
      "1. Yelp Fusion API: https://www.yelp.com/developers/documentation/v3/business_reviews",
      "2. Use a headless browser service (Browserless, ScrapingBee)",
      "3. Use a proxy rotation service with residential IPs",
      "4. Manual export from Yelp Business dashboard"
    ],
    "working_sources": [
      "Trustpilot (JSON-LD) - Works reliably",
