{
  "name": "voice-of-customer-datalake",
  "version": "1.0.0",
  "description": "Voice of the Customer Data Lake - Unified customer feedback intelligence platform",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix voc-datalake && npm install --prefix voc-datalake/frontend",
    "build:layers": "cd voc-datalake && chmod +x scripts/build-layers.sh && ./scripts/build-layers.sh",
    "dev": "npm run dev --prefix voc-datalake/frontend",
    "build": "npm run build --prefix voc-datalake/frontend",
    "lint": "npm run lint --prefix voc-datalake/frontend",
    "typecheck": "npm run typecheck --prefix voc-datalake/frontend",
    "typecheck:tests": "npm run typecheck:tests --prefix voc-datalake/frontend",
    "typecheck:cdk": "cd voc-datalake && npx tsc --noEmit",
    "typecheck:stream": "cd voc-datalake/lambda/stream && npx tsc --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:cdk && npm run typecheck:stream",
    "test": "npm run test --prefix voc-datalake/frontend -- --run",
    "test:backend": "cd voc-datalake && .venv/bin/python -m pytest lambda/ -q --no-header --tb=short",
    "test:plugins": "cd voc-datalake && .venv/bin/python -m pytest plugins/test_plugin_imports.py -q --no-header --tb=short --override-ini='addopts=' -p no:cacheprovider",
    "test:watch": "npm run test:watch --prefix voc-datalake/frontend",
    "test:coverage": "npm run test:coverage --prefix voc-datalake/frontend",
    "check": "npm run lint && npm run typecheck:all && npm run test && npm run test:backend && npm run test:plugins",
    "generate:manifests": "npm run generate:manifests --prefix voc-datalake",
    "generate:menu": "npm run generate:menu --prefix voc-datalake",
    "generate:config": "npm run generate:manifests && npm run generate:menu",
    "generate:workshop-artifacts": "npm run generate:workshop-artifacts --prefix voc-datalake",
    "validate:plugins": "npm run validate:plugins --prefix voc-datalake",
    "cdk": "npm run cdk --prefix voc-datalake --",
    "cdk:nag": "npm run cdk:nag --prefix voc-datalake",
    "cdk:diff": "npm run cdk --prefix voc-datalake -- diff",
    "cdk:synth": "npm run cdk --prefix voc-datalake -- synth",
    "cdk:bootstrap": "npm run cdk --prefix voc-datalake -- bootstrap",
    "deploy:infra": "npm run cdk --prefix voc-datalake -- deploy --all --require-approval never",
    "deploy:frontend": "npm run deploy:frontend --prefix voc-datalake/frontend",
    "deploy:all": "npm run check && npm run deploy:infra && npm run deploy:frontend",
    "destroy": "npm run cdk --prefix voc-datalake -- destroy --all"
  },
  "keywords": [
    "aws",
    "cdk",
    "datalake",
    "voice-of-customer",
    "analytics",
    "feedback",
    "customer-experience"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
